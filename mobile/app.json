{
  "expo": {
    "name": "Comandas",
    "slug": "comandas-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F7F8FA"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.johanotavo.comandas"
    },
    "extra": {
      "apiUrlNote": "Configura EXPO_PUBLIC_API_URL para apuntar al backend.",
      "eas": {
        "projectId": "b32eb509-a8b1-4103-b030-815ad1ba46a8"
      }
    },
    "plugins": [
      "expo-asset",
      "expo-font"
    ],
    "owner": "reyjohan"
  }
}
